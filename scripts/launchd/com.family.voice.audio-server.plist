<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.family.voice.audio-server</string>
	<key>ProgramArguments</key>
	<array>
		<string>/opt/local/bin/uvicorn</string>
		<string>claw_audio_server.main:app</string>
		<string>--host</string>
		<string>0.0.0.0</string>
		<string>--port</string>
		<string>8080</string>
	</array>
	<key>WorkingDirectory</key>
	<string>/Users/Shared/claw-calendar/packages/audio-server</string>
	<key>KeepAlive</key>
	<true/>
	<key>RunAtLoad</key>
	<true/>
	<key>StandardOutPath</key>
	<string>/tmp/claw-audio-server.log</string>
	<key>StandardErrorPath</key>
	<string>/tmp/claw-audio-server.error.log</string>
	<key>EnvironmentVariables</key>
	<dict>
		<key>PATH</key>
		<string>/opt/local/bin:/usr/local/bin:/usr/bin:/bin</string>
	</dict>
</dict>
</plist>
