{
  "name": "@claw/kitchen-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "claw-kitchen": "./dist/bin/claw-kitchen.js"
  },
  "files": [
    "dist",
